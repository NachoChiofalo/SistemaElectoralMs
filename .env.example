# ===================== ENVIRONMENT =====================
NODE_ENV=development

# ===================== DATABASE (PostgreSQL) =====================
# Opcion 1 (recomendada): DATABASE_URL (Supabase o cualquier PostgreSQL remoto)
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Opcion 2: Variables individuales (usado por Docker Compose / desarrollo local)
# Use 'postgres' for Docker Compose (matches service name), or 'localhost' for local development
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sistema_electoral
DB_USER=electoral_user
DB_PASSWORD=electoral_password

# ===================== AUTH SERVICE =====================
AUTH_PORT=3002
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRATION=2h
REFRESH_TOKEN_EXPIRATION=7d

# ===================== GATEWAY SERVICE =====================
GATEWAY_PORT=8080
AUTH_SERVICE_URL=http://localhost:3002
PADRON_SERVICE_URL=http://localhost:3001
WEB_ADMIN_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080

# ===================== PADRON SERVICE =====================
PADRON_PORT=3001
CORS_ORIGIN=http://localhost:3000
